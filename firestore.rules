rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules
    match /orders/{orderId} {
      allow read, write: if true;
    }

    match /waiter_calls/{callId} {
      allow read, write: if true;
    }

    match /menu/{itemId} {
      allow read, write: if true;
    }

    match /tables/{tableId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /staff/{staffId} {
      allow read, write: if true;
    }

    match /stock/{stockId} {
      allow read, write: if true;
    }

    match /expenses/{expenseId} {
      allow read, write: if true;
    }

    match /coupons/{couponId} {
      allow read, write: if true;
    }
  }
}
